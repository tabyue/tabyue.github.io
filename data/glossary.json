        { "en": "Eigenvalue / Eigenvector", "zh": "特征值/特征向量", "abbr": "", "def": "Av=λv，变换中方向不变的向量和缩放系数。", "module": "linear-algebra" },
        { "en": "Positive Definite Matrix", "zh": "正定矩阵", "abbr": "PD", "def": "所有特征值 > 0 的对称矩阵。质量矩阵和协方差矩阵都是正定的。", "module": "linear-algebra" },
        { "en": "Convex Optimization", "zh": "凸优化", "abbr": "", "def": "目标函数和约束集都是凸的优化问题。局部最优即全局最优。", "module": "calculus-optimization" },
        { "en": "KKT Conditions", "zh": "KKT 条件", "abbr": "KKT", "def": "Karush-Kuhn-Tucker 条件，约束优化问题最优解的必要条件。", "module": "calculus-optimization" },
        { "en": "Bayesian Inference", "zh": "贝叶斯推断", "abbr": "", "def": "P(A|B)∝P(B|A)P(A)。后验 ∝ 似然 × 先验。机器人 SLAM/滤波的基础。", "module": "probability-statistics" },
        { "en": "Kalman Filter", "zh": "卡尔曼滤波", "abbr": "KF", "def": "线性高斯系统的最优状态估计器。预测-更新两步递推。", "module": "probability-statistics" },
