        { "en": "Servo Motor", "zh": "伺服电机", "abbr": "", "def": "带反馈的精密电机，可精确控制位置/速度/力矩。", "module": "mechanical-design" },
        { "en": "Brushless DC Motor", "zh": "无刷直流电机", "abbr": "BLDC", "def": "用电子换向替代电刷的高效电机，机器人关节常用。", "module": "mechanical-design" },
        { "en": "Harmonic Drive", "zh": "谐波减速器", "abbr": "", "def": "高减速比(>50:1)、零齿隙的精密减速器。协作臂标配但贵。", "module": "mechanical-design" },
        { "en": "Planetary Gearbox", "zh": "行星减速器", "abbr": "", "def": "高承载、紧凑结构的减速器。工业机器人常用。", "module": "mechanical-design" },
        { "en": "Encoder", "zh": "编码器", "abbr": "", "def": "测量旋转角度/位置的传感器。分增量式（AB相脉冲）和绝对式（输出角度值）。", "module": "sensors-hardware" },
        { "en": "Gripper", "zh": "夹爪/抓手", "abbr": "", "def": "机器人末端抓取工具。分二指平行/三指自适应/吸盘/软体夹爪。", "module": "mechanical-design" },
        { "en": "Dexterous Hand", "zh": "灵巧手", "abbr": "", "def": "具有多指多关节的仿人机器手，可执行精细操作。", "module": "mechanical-design" },
        { "en": "URDF", "zh": "统一机器人描述格式", "abbr": "URDF", "def": "Unified Robot Description Format，XML 格式的机器人模型描述（连杆+关节+几何+惯性）。", "module": "ros2" }
      ]
    },
