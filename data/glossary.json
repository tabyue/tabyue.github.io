        { "en": "LeRobot", "zh": "LeRobot 框架", "abbr": "", "def": "HuggingFace 开源的模仿学习/强化学习机器人框架，支持数据采集和策略训练。", "module": "imitation-learning" },
        { "en": "Open X-Embodiment", "zh": "开放跨具身数据集", "abbr": "OXE", "def": "Google 联合多家机构发布的大规模跨机器人操作数据集。", "module": "embodied-data-engineering" },
        { "en": "RLDS (Reinforcement Learning Datasets)", "zh": "强化学习数据集格式", "abbr": "RLDS", "def": "Google 定义的机器人轨迹数据标准格式(TFRecord)，OXE 采用。", "module": "embodied-data-engineering" }
      ]
    },
